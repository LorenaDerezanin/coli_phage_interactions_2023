watch_file environment.yml

# Source conda directly — direnv runs in a bare bash shell without .zshrc/.bashrc,
# so the conda shell function is not available by default.
CONDA_SH="${CONDA_PREFIX:-$HOME/miniconda3}/etc/profile.d/conda.sh"
if [ -f "$CONDA_SH" ]; then
  . "$CONDA_SH"
elif [ -f "$HOME/miniconda3/etc/profile.d/conda.sh" ]; then
  . "$HOME/miniconda3/etc/profile.d/conda.sh"
else
  echo "conda not found; install Miniconda before using this repository."
  exit 1
fi

conda activate phage_env
